# Email Configuration
MAIL_HOST=mail.example.com
MAIL_USER=bot@example.com
MAIL_PASS=your_email_password
IMAP_PORT=993
SMTP_PORT=465
IMAP_MAILBOX=INBOX
IMAP_MAX=10

# OpenAI API Key (optional - uses fallback responses if not provided)
OPENAI_API_KEY=sk-your-openai-api-key

# CC Always (optional - email to always CC on replies)
CC_ALWAYS=

# Google OAuth (optional - for Banorte handler gog CLI integration)
GOG_ACCOUNT=your-google-account@gmail.com
GOG_KEYRING_PASSWORD=your_gog_keyring_password